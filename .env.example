# Tru-find-ai backend environment template.
# Copy to .env (gitignored) and fill in values for local dev.
# Production / staging values live in Railway environment variables.

# === Application ===
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL

# === HTTP layer ===
REQUEST_ID_HEADER=X-Request-ID
ALLOWED_ORIGINS=["http://localhost:5173"]
RATE_LIMIT_PER_MINUTE=60

# === Observability (Sentry — stub until A.12) ===
SENTRY_DSN=

# === Phase B placeholders (Postgres / Redis / auth) ===
DATABASE_URL=
REDIS_URL=
SESSION_SECRET=
ENCRYPTION_KEY=
MAGIC_LINK_TOKEN_TTL_MIN=15

# === Phase E placeholders (Stripe — ADR-023, ADR-043) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Phase F placeholders (Twilio — gated on 10DLC per ADR-025) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Phase D / H placeholders (LLM, Google Places — gated on §5.6 / §5.11) ===
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
GOOGLE_PLACES_API_KEY=
