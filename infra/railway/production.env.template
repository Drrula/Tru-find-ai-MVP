# TruFindAI production environment variables.
# Set values via Railway dashboard per service per environment.
# DO NOT commit values to this file.
# Production secrets are sensitive — coordinate with security policy.
#
# Production URL (Andrew, 2026-05-09): https://pl300-production.up.railway.app
# DO NOT deploy or mutate production without explicit approval.

# === Application ===
APP_ENV=production
LOG_LEVEL=INFO

# === HTTP layer ===
REQUEST_ID_HEADER=X-Request-ID
ALLOWED_ORIGINS=["https://pl300-production.up.railway.app"]
RATE_LIMIT_PER_MINUTE=60

# === Observability ===
SENTRY_DSN=

# === Phase B placeholders ===
DATABASE_URL=
REDIS_URL=
SESSION_SECRET=
ENCRYPTION_KEY=
MAGIC_LINK_TOKEN_TTL_MIN=15

# === Phase E placeholders (Stripe — LIVE mode) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Phase F placeholders (Twilio — registered 10DLC sender per ADR-025) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Phase D / H placeholders ===
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
GOOGLE_PLACES_API_KEY=

# === Frontend (web service) ===
# Build-time variables: must be set BEFORE Vite build runs.
VITE_API_BASE_URL=https://pl300-production.up.railway.app
VITE_SENTRY_DSN=
VITE_APP_ENV=production
