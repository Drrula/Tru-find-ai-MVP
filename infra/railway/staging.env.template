# TruFindAI staging environment variables.
# Set values via Railway dashboard per service per environment.
# DO NOT commit values to this file.

# === Application ===
APP_ENV=staging
LOG_LEVEL=INFO

# === HTTP layer ===
REQUEST_ID_HEADER=X-Request-ID
ALLOWED_ORIGINS=["https://web-staging.up.railway.app"]
RATE_LIMIT_PER_MINUTE=60

# === Observability (Sentry — stub until A.12) ===
SENTRY_DSN=

# === Phase B placeholders (Postgres / Redis / auth) ===
DATABASE_URL=
REDIS_URL=
SESSION_SECRET=
ENCRYPTION_KEY=
MAGIC_LINK_TOKEN_TTL_MIN=15

# === Phase E placeholders (Stripe — TEST mode) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Phase F placeholders (Twilio — sandbox; pre-10DLC per ADR-025) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Phase D / H placeholders (LLM, Places — gated on §5.6 / §5.11) ===
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
GOOGLE_PLACES_API_KEY=

# === Frontend (web service) ===
# Build-time variables: must be set BEFORE Vite build runs.
VITE_API_BASE_URL=https://api-staging.up.railway.app
VITE_SENTRY_DSN=
VITE_APP_ENV=staging
