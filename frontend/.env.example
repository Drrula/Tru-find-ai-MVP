# Frontend environment template.
# Copy to .env.local for local dev (gitignored at the repo root).
# Production / staging values live in Railway environment variables
# per ADR-026.

# API base URL. Empty = relative URLs (works with the Vite dev proxy).
# In staging/production set to the backend origin, e.g.
#   VITE_API_BASE_URL=https://api.trufindai-staging.up.railway.app
VITE_API_BASE_URL=
