# Frontend environment template.
# Copy to .env.local for local dev (gitignored at the repo root).
# Production / staging values live in Railway environment variables
# per ADR-026.

# API base URL. Empty = relative URLs (works with the Vite dev proxy).
# In staging/production set to the backend origin, e.g.
#   VITE_API_BASE_URL=https://api.trufindai-staging.up.railway.app
VITE_API_BASE_URL=

# Sentry browser DSN. Empty = Sentry disabled (no-op). Set per Railway
# environment to a real Sentry project DSN to enable client-side error
# capture (per ADR-030, A.12).
VITE_SENTRY_DSN=

# Optional explicit environment label for Sentry events. Falls back to
# Vite's MODE (development / production / test) when empty.
VITE_APP_ENV=
